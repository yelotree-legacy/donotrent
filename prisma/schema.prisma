generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Rental company tenants. Each company can add and manage their own DNR entries.
model Company {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  email           String        @unique
  phone           String?
  city            String?
  state           String?
  passwordHash    String
  verified        Boolean       @default(false)
  isAdmin         Boolean       @default(false)

  // Billing & plan
  // Plan: free | starter | pro | business | enterprise
  plan                  String    @default("free")
  // Subscription state from Stripe: trialing | active | past_due | canceled | incomplete | unpaid | none
  stripeStatus          String    @default("none")
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  stripePriceId         String?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  trialEndsAt           DateTime?
  checksUsedThisPeriod  Int       @default(0)
  // For Pro+ plans, the API can be called with this token (bearer)
  apiKeyHash            String?   @unique
  apiKeyHint            String?   // last 4 chars for display

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  entries         DnrEntry[]    @relation("EntryCreator")
  reports         Report[]
  searchLogs      SearchLog[]
  auditEvents     AuditEvent[]
  checks          CheckSession[] @relation("CompanyChecks")
  brokerReviews   BrokerReview[] @relation("BrokerReviews")
}

// A broker / agent in the rental ecosystem — a middleman who finds
// customers, takes commissions, sometimes sub-rents. Reviewed by operators
// who've worked with them.
model Broker {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  aliases         String?        // JSON array
  email           String?
  phone           String?
  website         String?
  instagram       String?        // handle
  city            String?
  state           String?
  description     String?

  // Denormalized for list rendering
  reviewCount     Int            @default(0)
  avgRating       Float?         // 1.0–5.0; null = no reviews

  status          String         @default("ACTIVE") // ACTIVE | DISPUTED | RESOLVED

  reviews         BrokerReview[]
  disputes        BrokerDispute[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([slug])
  @@index([state])
}

model BrokerReview {
  id              String   @id @default(cuid())
  brokerId        String
  broker          Broker   @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  reviewerCompanyId String
  reviewerCompany   Company @relation("BrokerReviews", fields: [reviewerCompanyId], references: [id], onDelete: Cascade)

  rating          Int       // 1-5 stars
  // experienceType: payment | fraud | communication | quality | other
  experienceType  String?
  title           String
  body            String

  incidentDate    DateTime?
  damageAmount    Float?
  resolved        Boolean   @default(false)

  disputes        BrokerDispute[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([brokerId])
  @@index([reviewerCompanyId])
  @@index([createdAt])
}

// Public dispute against a broker listing or a specific review. Brokers
// (or someone representing them) can challenge without needing an
// operator account. Goes into a moderation queue.
model BrokerDispute {
  id              String         @id @default(cuid())
  brokerId        String
  broker          Broker         @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  reviewId        String?
  review          BrokerReview?  @relation(fields: [reviewId], references: [id], onDelete: SetNull)

  filerName       String
  filerContact    String
  filerRole       String?        // broker | associate | other
  reason          String         // rebuttal / explanation

  // status: OPEN | IN_REVIEW | RESOLVED | REJECTED
  status          String         @default("OPEN")
  resolvedAt      DateTime?
  resolution      String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([brokerId])
  @@index([status])
}

// A "source" is one origin of DNR data — e.g. a partner rental company's
// public DNR page, or our own network of operator uploads. Cross-check
// queries aggregate matches across every source.
model Source {
  id              String     @id @default(cuid())
  slug            String     @unique
  name            String
  kind            String     @default("scraped") // scraped | network | manual | partner
  url             String?
  region          String?    // "South Florida", "National", etc.
  description     String?
  trustScore      Int        @default(70)        // 0-100, used in scoring weight
  lastSyncedAt    DateTime?
  syncFrequency   String?    // "daily" | "weekly" | "manual"
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())

  entries         DnrEntry[]

  @@index([slug])
}

// Core record. One row per person flagged on the do-not-rent list.
// fullName + licenseId are the two primary search keys.
model DnrEntry {
  id              String        @id @default(cuid())

  // Identity (the two primary search keys)
  fullName        String
  fullNameNorm    String        // normalized lowercase, alphanumeric-only — fast LIKE search
  firstName       String?
  middleName      String?
  lastName        String?
  aliases         String?       // JSON-encoded array of alternate spellings

  licenseId       String?       // captured separately so it can be searched directly
  licenseIdNorm   String?       // normalized: alphanumeric-only, uppercase
  licenseState    String?       // two-letter state/province code
  licenseExpiry   DateTime?
  dateOfBirth     DateTime?

  // Status: ACTIVE | ARCHIVED | REFORMED | DISPUTED
  status          String        @default("ACTIVE")
  // Severity: LOW | MEDIUM | HIGH | CRITICAL
  severity        String        @default("MEDIUM")

  // Incident summary (denormalized for fast list rendering / search snippets)
  primaryReason   String        // short one-liner reason
  detailedNotes   String?       // long-form description
  damageAmount    Float?        // total $ damages claimed
  incidentDate    DateTime?
  incidentCity    String?
  incidentState   String?

  // Provenance
  sourceId        String?
  source          Source?       @relation(fields: [sourceId], references: [id])
  sourceUrl       String?       // e.g. supremesportrental original URL
  importedFrom    String?       // "supremesportrental.com" for seeded entries (legacy)
  createdById     String?
  createdBy       Company?      @relation("EntryCreator", fields: [createdById], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  categories      EntryCategory[]
  photos          Photo[]
  reasons         Reason[]
  reports         Report[]
  disputes        Dispute[]

  @@index([fullNameNorm])
  @@index([licenseIdNorm])
  @@index([lastName])
  @@index([status])
  @@index([sourceId])
}

// Many-to-many: each entry can be tagged with multiple violation categories.
// Lets searchers filter by "vehicle theft", "nonpayment", etc.
model Category {
  id        String           @id @default(cuid())
  slug      String           @unique
  label     String
  entries   EntryCategory[]
}

model EntryCategory {
  entryId    String
  categoryId String
  entry      DnrEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  @@id([entryId, categoryId])
  @@index([categoryId])
}

// Photos: license front, license back, vehicle damage, etc.
// One entry can have many photos.
model Photo {
  id        String     @id @default(cuid())
  entryId   String
  entry     DnrEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  url       String     // public URL or /uploads/... path
  // PhotoKind: LICENSE_FRONT | LICENSE_BACK | PERSON | DAMAGE | DOCUMENT | OTHER
  kind      String     @default("LICENSE_FRONT")
  caption   String?
  createdAt DateTime   @default(now())
}

// Granular reasons — separate from the primary one-liner so multiple incidents per entry
// can be listed as a checklist. Searchable via full-text on `text`.
model Reason {
  id        String   @id @default(cuid())
  entryId   String
  entry    DnrEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  text      String
  amount    Float?
  occurredAt DateTime?
  createdAt DateTime @default(now())
  @@index([entryId])
}

// A company endorsing/corroborating an existing entry — adds weight to a record.
model Report {
  id              String   @id @default(cuid())
  entryId         String
  entry           DnrEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  reportingCoId   String
  reportingCo     Company  @relation(fields: [reportingCoId], references: [id], onDelete: Cascade)
  description     String
  evidenceUrls    String?  // JSON array
  incidentDate    DateTime?
  createdAt       DateTime @default(now())
  @@unique([entryId, reportingCoId])
}

// People can dispute being on the list. Companies/admins review.
model Dispute {
  id        String         @id @default(cuid())
  entryId   String
  entry     DnrEntry       @relation(fields: [entryId], references: [id], onDelete: Cascade)
  filerName String
  filerContact String
  reason    String
  // DisputeStatus: OPEN | IN_REVIEW | RESOLVED | REJECTED
  status    String         @default("OPEN")
  createdAt DateTime       @default(now())
  resolvedAt DateTime?
  resolution String?
}

// Search analytics — what people are looking up.
model SearchLog {
  id          String   @id @default(cuid())
  query       String
  field       String   // "name" | "license" | "any"
  resultsCount Int
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ip          String?
  createdAt   DateTime @default(now())
  @@index([createdAt])
}

// One row per Rent Report run. Persists the cross-source verdict + any
// Stripe Identity verification kicked off for the renter being checked.
model CheckSession {
  id              String     @id @default(cuid())

  // Inputs
  fullName        String?
  licenseId       String?
  dateOfBirth     DateTime?

  // Cached cross-source verdict
  verdict         String?    // APPROVE | REVIEW | DECLINE
  riskScore       Int?
  totalHits       Int        @default(0)
  matchedSources  Int        @default(0)
  worstSeverity   String?

  // Stripe Identity state
  // status: not_started | pending | verified | requires_input | canceled | failed
  idvStatus       String     @default("not_started")
  idvSessionId    String?    @unique // Stripe verification_session id
  idvClientSecret String?
  idvUrl          String?
  idvReturnUrl    String?

  // Verified data extracted from the document
  idvVerifiedName       String?
  idvVerifiedFirstName  String?
  idvVerifiedLastName   String?
  idvVerifiedDob        DateTime?
  idvDocType            String?
  idvDocNumber          String?    // license number from IDV
  idvDocCountry         String?
  idvDocState           String?
  idvDocExpiry          DateTime?
  idvSelfieMatch        Boolean?
  idvErrorCode          String?
  idvCompletedAt        DateTime?

  // OFAC sanctions match (free, public US Treasury data)
  // status: not_run | clear | match | error
  ofacStatus      String     @default("not_run")
  ofacMatchCount  Int        @default(0)
  ofacMatchesJson String?    // JSON: [{uid, name, programs, score}]
  ofacCheckedAt   DateTime?

  // Checkr criminal + sex offender (paid via CHECKR_API_KEY)
  // status: not_run | pending | clear | consider | suspended | error
  checkrStatus      String   @default("not_run")
  checkrCandidateId String?
  checkrReportId    String?  @unique
  checkrAdjudication String? // engaged | post_adverse_action | pre_adverse_action | none
  checkrFindingsJson String? // JSON: [{type, severity, summary}]
  checkrErrorCode   String?
  checkrCompletedAt DateTime?

  companyId       String?
  company         Company?   @relation("CompanyChecks", fields: [companyId], references: [id], onDelete: SetNull)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([companyId])
  @@index([createdAt])
  @@index([idvSessionId])
  @@index([checkrReportId])
}

// Tamper-evident log of mutations for trust.
model AuditEvent {
  id        String   @id @default(cuid())
  actorId   String?
  actor     Company? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  target    String
  metadata  String?  // JSON
  createdAt DateTime @default(now())
  @@index([createdAt])
}

