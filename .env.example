# Postgres — required. Use the connection strings Vercel/Neon provide.
# DATABASE_URL is the pooled URL (PgBouncer). DIRECT_URL is the direct connection
# used only for `prisma migrate`. On Neon both are in the dashboard.
DATABASE_URL="postgres://user:pass@host/db?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgres://user:pass@host/db?sslmode=require&connect_timeout=15"

# iron-session cookie encryption secret (≥32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_PASSWORD="generate-a-32-char-min-secret-please"

# Vercel Blob — optional locally. Required in production for license uploads.
# Get from Vercel dashboard → Storage → Blob → New store.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Stripe Identity — optional. When unset, the IDV button shows a config notice.
# Get the secret key from Stripe dashboard → Developers → API keys.
# The webhook secret comes from setting up an endpoint at:
#   https://<your-domain>/api/idv/webhook
# subscribed to:
#   identity.verification_session.verified
#   identity.verification_session.requires_input
#   identity.verification_session.canceled
#   identity.verification_session.processing
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Stripe Billing — required to sell subscriptions. Create the products and
# recurring monthly prices in Stripe dashboard, then paste the price IDs here.
# Price IDs look like: price_1Xxxxx
STRIPE_PRICE_STARTER="price_xxx"   # $49/mo
STRIPE_PRICE_PRO="price_xxx"       # $149/mo
STRIPE_PRICE_PRO_PLUS="price_xxx"  # $399/mo (was previously named STRIPE_PRICE_BUSINESS — that name still works as fallback)

# Checkr — optional. When set, the /check/[id] page exposes a "Run Checkr
# report" button that triggers a National Sex Offender + criminal check.
# Sign up at https://checkr.com (requires business verification, takes a
# few days for live keys). Test keys work immediately.
CHECKR_API_KEY=""           # e.g. f1234abcd... or test_xxxxx
CHECKR_PACKAGE="tasker_basic_plus"
CHECKR_WEBHOOK_SECRET=""    # optional, signs incoming /api/checkr/webhook
# Optional: separate webhook secret for billing events. If unset, falls back
# to STRIPE_WEBHOOK_SECRET (you can use the same Stripe webhook endpoint and
# subscribe to both identity.* and customer.subscription.* events).
# STRIPE_BILLING_WEBHOOK_SECRET="whsec_xxx"

# OFAC — no env vars needed. The matcher fetches the public US Treasury
# SDN list at https://www.treasury.gov/ofac/downloads/sdn.csv and caches
# in-process for 24h. Free forever.
